          {
            "type": "paragraph",
            "version": 1,
            "children": [
              {
                "type": "text",
                "version": 1,
                "text": "Whether 'tis nobler in the mind to suffer",
                "detail": 0,
                "format": 0,
                "mode": "normal",
                "style": ""
              }
            ],
            "format": "",
            "indent": 0,
            "direction": null,
