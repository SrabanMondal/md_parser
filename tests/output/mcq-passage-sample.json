            "textStyle": ""
          },
          {
            "type": "paragraph",
            "version": 1,
            "children": [
              {
                "type": "text",
                "version": 1,
                "text": "That flesh is heir to: 'tis a consummation",
                "detail": 0,
                "format": 0,
                "mode": "normal",
                "style": ""
              }
            ],
            "format": "",
            "indent": 0,
            "direction": null,
