          },
          {
            "type": "paragraph",
            "version": 1,
            "children": [
              {
                "type": "text",
                "version": 1,
                "text": "Devoutly to be wish'd. To die, to sleep;",
                "detail": 0,
                "format": 0,
                "mode": "normal",
                "style": ""
              }
            ],
            "format": "",
            "indent": 0,
