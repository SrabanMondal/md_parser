            "textStyle": ""
          },
          {
            "type": "paragraph",
            "version": 1,
            "children": [
              {
                "type": "text",
                "version": 1,
                "text": "The slings and arrows of outrageous fortune,",
                "detail": 0,
                "format": 0,
                "mode": "normal",
                "style": ""
              }
            ],
            "format": "",
            "indent": 0,
            "direction": null,
            "textFormat": 0,
            "textStyle": ""
          },
          {
            "type": "paragraph",
            "version": 1,
            "children": [
              {
                "type": "text",
                "version": 1,
                "text": "Or to take arms against a sea of troubles",
                "detail": 0,
                "format": 0,
                "mode": "normal",
                "style": ""
              }
            ],
            "format": "",
            "indent": 0,
            "direction": null,
            "textFormat": 0,
            "textStyle": ""
          },
          {
            "type": "paragraph",
            "version": 1,
            "children": [
              {
                "type": "text",
                "version": 1,
                "text": "And by opposing end them. To die—to sleep,",
                "detail": 0,
                "format": 0,
                "mode": "normal",
                "style": ""
              }
            ],
            "format": "",
            "indent": 0,
            "direction": null,
