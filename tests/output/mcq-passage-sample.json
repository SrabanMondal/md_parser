          },
          {
            "type": "paragraph",
            "version": 1,
            "children": [
              {
                "type": "text",
                "version": 1,
                "text": "No more; and by a sleep to say we end",
                "detail": 0,
                "format": 0,
                "mode": "normal",
                "style": ""
              }
            ],
            "format": "",
            "indent": 0,
            "direction": null,
            "textFormat": 0,
            "textStyle": ""
          },
          {
            "type": "paragraph",
            "version": 1,
            "children": [
              {
                "type": "text",
                "version": 1,
                "text": "The heart-ache and the thousand natural shocks",
                "detail": 0,
                "format": 0,
                "mode": "normal",
                "style": ""
              }
            ],
            "format": "",
            "indent": 0,
            "direction": null,
